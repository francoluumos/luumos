# Luumos — Environment Variable Template
# Copy this file to `.env.local` (gitignored) and fill in real values.
# NEVER commit .env, .env.local, or any file with real secrets.

# ============================================
# Supabase
# ============================================
# Project URL
SUPABASE_URL=https://kxuppoyqtzktqhbdrcya.supabase.co

# Anon (public) key — safe to expose in client (Lovable frontend)
# Holen unter: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER ONLY, NEVER expose to client
# Holen unter: Supabase Dashboard → Project Settings → API → service_role (NUR FÜR EDGE FUNCTIONS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Project ref — used by Supabase CLI
SUPABASE_PROJECT_REF=kxuppoyqtzktqhbdrcya

# ============================================
# LLM provider for Job-Check analysis
# ============================================
# Pick one. Used in Edge Function `analyze-job`.
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OR OpenAI
# OPENAI_API_KEY=sk-your-key-here

# Model identifier — see prompts/job-check-system.md for current choice
LLM_MODEL=claude-sonnet-4-6

# ============================================
# Newsletter (Beehiiv recommended)
# ============================================
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUBLICATION_ID=pub_your-publication-id

# ============================================
# Site config
# ============================================
SITE_URL=https://luumos.io
SITE_LOCALE=de-CH

# ============================================
# Analytics (optional — Plausible recommended for DSG)
# ============================================
# PLAUSIBLE_DOMAIN=luumos.io
